{
  "name": "stahnsdorf-cemetery-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy:firestore": "firebase deploy --only firestore",
    "emulators": "firebase emulators:start",
    "emulators:seed": "npx tsx scripts/seed-emulator.ts",
    "test:e2e": "firebase emulators:exec \"npx playwright test\"",
    "test:e2e:ui": "firebase emulators:exec \"npx playwright test --ui\"",
    "test:rules": "firebase emulators:exec \"npx vitest run tests/rules/firestore.rules.test.ts\""
  },
  "dependencies": {
    "firebase": "^12.11.0",
    "leaflet": "^1.9.4",
    "next": "^16.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@playwright/test": "^1.59.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "dotenv": "^17.4.0",
    "firebase-admin": "^13.7.0",
    "firebase-tools": "^15.13.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
