  "discovered_endpoints": [
    {
      "url": "https://www.wo-sie-ruhen.de/newapi?graveyard=18",
      "type": "jsonp",
      "purpose": "Cemetery details + all grave entries (flat array)",
      "response_fields_graveyard_details": [
        "geolat", "geolong", "name", "ort", "adresse", "telefon", "webseite",
        "oeffnungszeiten", "anfahrt", "beschreibung"
      ],
      "response_fields_graves": [
        "ID", "ordering", "graveyardID", "cityID", "name", "vorname",
        "geburtsort", "sterbeort", "geburtsdatum", "sterbedatum",
        "berufkat", "beruf", "lage", "grabid",
        "name2", "vorname2", "geburtsort2", "sterbeort2",
        "geburtsdatum2", "sterbedatum2", "beruf2", "lage2", "grabid2",
        "zoom_pic", "personImagePic", "audio", "audio_title",
        "autor", "ehrengrab", "architekt", "geolat", "geolong",
        "state", "hightlight"
      ]
    },
    {
      "url": "https://www.wo-sie-ruhen.de/newapi?grave={ID}",
      "type": "jsonp",
      "purpose": "Individual grave detail (same fields as above, used for modal popups)"
    },
    {
      "url": "https://www.wo-sie-ruhen.de/wsr-search?search={query}",
      "type": "jsonp",
      "purpose": "Global search across all cemeteries and graves"
    }
  ],

  "script_files": [
    {
      "type": "inline",
      "description": "Main page script block 1 - Leaflet map init, slick carousel, AJAX data load",
      "key_elements": [
        "L.map('graveYardMap') initialization",
        "50 custom marker icons (images/map/maker_1.png through maker_50.png)",
        "wsrIcon = L.Icon.extend({...}) with iconSize [35,35]",
        "Cookie-based consent check: $.cookie('mapSettings') == 'mapOn'",
        "JSONP call to newapi?graveyard=18",
        "Marker creation loop: $.each(graveyard.graves, ...)",
        "L.layerGroup() for graves layer",
        "OpenStreetMap HOT tile layer: https://{s}.tile.openstreetmap.fr/hot/{z}/{x}/{y}.png"
      ]
    },
    {
      "type": "inline",
      "description": "Main page script block 2 - Modal popups, search, audio player",
      "key_elements": [
        "Grave detail JSONP call to newapi?grave={ID}",
        "MediaElementPlayer for audio",
        "Search with JSONP to wsr-search endpoint",
        "nl2br helper function"
      ]
    }
  ],

